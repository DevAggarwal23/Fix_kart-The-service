rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Check if user is a worker
    function isWorker() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/workers/$(request.auth.uid));
    }
    
    // Validate required fields
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // Get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile
      allow create: if isOwner(userId);
      
      // Users can update their own profile
      allow update: if isOwner(userId) || isAdmin();
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // ============================================
    // WORKERS COLLECTION
    // ============================================
    
    match /workers/{workerId} {
      // Workers can read their own profile, admins can read all
      // Customers can read basic worker info
      allow read: if isOwner(workerId) || isAdmin() || isAuthenticated();
      
      // Workers can create their profile
      allow create: if isOwner(workerId);
      
      // Workers can update their own profile, admins can update any
      allow update: if isOwner(workerId) || isAdmin();
      
      // Only admins can delete workers
      allow delete: if isAdmin();
    }
    
    // ============================================
    // ADMINS COLLECTION
    // ============================================
    
    match /admins/{adminId} {
      // Only admins can read/write
      allow read, write: if isAdmin();
    }
    
    // ============================================
    // CATEGORIES COLLECTION
    // ============================================
    
    match /categories/{categoryId} {
      // Anyone can read categories
      allow read: if true;
      
      // Only admins can create/update/delete
      allow create, update, delete: if isAdmin();
    }
    
    // ============================================
    // SERVICES COLLECTION
    // ============================================
    
    match /services/{serviceId} {
      // Anyone can read services
      allow read: if true;
      
      // Only admins can create/update/delete
      allow create, update, delete: if isAdmin();
    }
    
    // ============================================
    // BOOKINGS COLLECTION
    // ============================================
    
    match /bookings/{bookingId} {
      // Customers can read their own bookings
      // Workers can read bookings assigned to them
      // Admins can read all
      allow read: if isOwner(resource.data.customerId) || 
                    (isWorker() && resource.data.workerId == request.auth.uid) ||
                    isAdmin();
      
      // Authenticated users can create bookings
      allow create: if isAuthenticated() && 
                      request.resource.data.customerId == request.auth.uid;
      
      // Customers can update their pending bookings
      // Workers can update assigned bookings (status changes)
      // Admins can update any
      allow update: if (isOwner(resource.data.customerId) && 
                        resource.data.status in ['pending', 'confirmed', 'assigned']) ||
                      (isWorker() && resource.data.workerId == request.auth.uid) ||
                      isAdmin();
      
      // Only admins can delete bookings
      allow delete: if isAdmin();
    }
    
    // ============================================
    // PAYMENTS COLLECTION
    // ============================================
    
    match /payments/{paymentId} {
      // Customers can read their own payments
      allow read: if isOwner(resource.data.customerId) || isAdmin();
      
      // System creates payments (via Cloud Functions)
      allow create: if false;
      
      // System updates payments (via Cloud Functions)
      allow update: if false;
      
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // ============================================
    // REFUNDS COLLECTION
    // ============================================
    
    match /refunds/{refundId} {
      // Customers can read their own refunds
      allow read: if isOwner(resource.data.customerId) || isAdmin();
      
      // System creates/updates refunds
      allow create, update: if false;
      
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // ============================================
    // WALLET TRANSACTIONS COLLECTION
    // ============================================
    
    match /walletTransactions/{transactionId} {
      // Users can read their own transactions
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // System creates transactions
      allow create, update, delete: if false;
    }
    
    // ============================================
    // REVIEWS COLLECTION
    // ============================================
    
    match /reviews/{reviewId} {
      // Approved reviews are public
      // Users can read their own reviews regardless of status
      allow read: if resource.data.status == 'approved' || 
                    isOwner(resource.data.customerId) ||
                    isAdmin();
      
      // Authenticated users can create reviews
      allow create: if isAuthenticated() && 
                      request.resource.data.customerId == request.auth.uid;
      
      // Users can update their own reviews within time limit
      allow update: if isOwner(resource.data.customerId) || isAdmin();
      
      // Users can delete their own reviews
      allow delete: if isOwner(resource.data.customerId) || isAdmin();
    }
    
    // ============================================
    // REVIEW HELPFUL COLLECTION
    // ============================================
    
    match /reviewHelpful/{helpfulId} {
      // Anyone can read
      allow read: if true;
      
      // Authenticated users can mark helpful
      allow create, delete: if isAuthenticated() && 
                              helpfulId.matches('^.+_' + request.auth.uid + '$');
    }
    
    // ============================================
    // REVIEW REPORTS COLLECTION
    // ============================================
    
    match /reviewReports/{reportId} {
      // Users can read their own reports, admins can read all
      allow read: if isOwner(resource.data.reportedBy) || isAdmin();
      
      // Authenticated users can report
      allow create: if isAuthenticated() && 
                      request.resource.data.reportedBy == request.auth.uid;
      
      // Only admins can update/delete reports
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // NOTIFICATIONS COLLECTION
    // ============================================
    
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isOwner(resource.data.userId);
      
      // System creates notifications
      allow create: if false;
      
      // Users can mark their notifications as read
      allow update: if isOwner(resource.data.userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
      
      // Users can delete their own notifications
      allow delete: if isOwner(resource.data.userId);
    }
    
    // ============================================
    // FCM TOKENS COLLECTION
    // ============================================
    
    match /fcmTokens/{tokenId} {
      // Users can manage their own tokens
      allow read, create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.userId);
    }
    
    // ============================================
    // ADDRESSES COLLECTION (User subcollection)
    // ============================================
    
    match /users/{userId}/addresses/{addressId} {
      allow read, write: if isOwner(userId);
    }
    
    // ============================================
    // FAVORITES COLLECTION (User subcollection)
    // ============================================
    
    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if isOwner(userId);
    }
    
    // ============================================
    // WORKER DOCUMENTS COLLECTION
    // ============================================
    
    match /workerDocuments/{docId} {
      // Workers can read their own documents
      allow read: if isOwner(resource.data.workerId) || isAdmin();
      
      // Workers can upload documents
      allow create: if isWorker() && 
                      request.resource.data.workerId == request.auth.uid;
      
      // Workers can update their own unverified documents
      allow update: if (isOwner(resource.data.workerId) && 
                        resource.data.verified != true) || 
                      isAdmin();
      
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // ============================================
    // COUPONS COLLECTION
    // ============================================
    
    match /coupons/{couponId} {
      // Active coupons can be read by authenticated users
      allow read: if isAuthenticated() && resource.data.status == 'active';
      
      // All coupon access for admins
      allow read, write: if isAdmin();
    }
    
    // ============================================
    // AI CONVERSATIONS COLLECTION
    // ============================================
    
    match /aiConversations/{conversationId} {
      // Users can read their own conversations
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // System creates conversations
      allow create, update, delete: if false;
    }
    
    // ============================================
    // AI ESTIMATES COLLECTION
    // ============================================
    
    match /aiEstimates/{estimateId} {
      // Users can read their own estimates
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // System creates estimates
      allow create, update, delete: if false;
    }
    
    // ============================================
    // ACTIVITIES COLLECTION (Admin logs)
    // ============================================
    
    match /activities/{activityId} {
      // Only admins can read activities
      allow read: if isAdmin();
      
      // System creates activities
      allow create, update, delete: if false;
    }
    
    // ============================================
    // SETTINGS COLLECTION
    // ============================================
    
    match /settings/{settingId} {
      // Platform settings readable by all
      allow read: if settingId == 'platform';
      
      // All settings readable by admin
      allow read: if isAdmin();
      
      // Only admins can write
      allow write: if isAdmin();
    }
    
    // ============================================
    // OTP COLLECTION (Temporary)
    // ============================================
    
    match /otps/{otpId} {
      // System manages OTPs
      allow read, write: if false;
    }
    
    // ============================================
    // DEFAULT DENY
    // ============================================
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
