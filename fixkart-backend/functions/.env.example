# ===================================
# FixKart Firebase Backend Environment Variables
# ===================================
# Copy this file to .env and fill in the values
# NEVER commit .env file to version control

# ===================================
# FIREBASE
# ===================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ===================================
# RAZORPAY
# ===================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ===================================
# OPENAI
# ===================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ===================================
# GOOGLE CLOUD
# ===================================
# For Google Vision API, set up Application Default Credentials
# or provide service account key path
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ===================================
# TWILIO (For SMS/OTP)
# ===================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ===================================
# NODEMAILER (Email)
# ===================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=FixKart <noreply@fixkart.com>

# ===================================
# GOOGLE MAPS
# ===================================
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ===================================
# JWT
# ===================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=7d

# ===================================
# APP CONFIG
# ===================================
NODE_ENV=development
APP_URL=https://fixkart.com
ADMIN_EMAIL=admin@fixkart.com

# ===================================
# RATE LIMITING
# ===================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
